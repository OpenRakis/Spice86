<Application
    x:Class="Spice86.Tests.UI.TestApp"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
    xmlns:semi="https://irihi.tech/semi"
    RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Spice86/Views/Assets/ControlThemes.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <dialogHostAvalonia:DialogHostStyles />
        <semi:SemiTheme Locale="en-US" />
        <semi:DockSemiTheme Locale="en-US" />
        <StyleInclude Source="avares://Spice86/Views/Styles/Spice86.axaml" />
    </Application.Styles>

</Application>

<UserControl
	x:Class="Spice86.Views.UserControls.MemorySearchBarUserControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:Spice86.ViewModels"
	d:DesignHeight="60"
	d:DesignWidth="1200"
	x:CompileBindings="True"
	x:DataType="viewModels:IMemorySearchViewModel"
	mc:Ignorable="d">
	<Border
		IsVisible="{Binding IsSearchingMemory}"
		Margin="0"
		Padding="8"
		Background="{Binding $parent[Window].Background}"
		BorderBrush="{Binding $parent[Window].Foreground}"
		BorderThickness="1">
		<Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
			<TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Memory search" FontWeight="Bold" />
			<RadioButton Grid.Column="1" GroupName="SearchDataType" Content="Binary" IsChecked="{Binding SearchDataTypeIsBinary}" Command="{Binding SetSearchDataTypeToBinaryAction}" />
			<RadioButton Grid.Column="2" Margin="8,0,0,0" GroupName="SearchDataType" Content="ASCII" IsChecked="{Binding SearchDataTypeIsAscii}" Command="{Binding SetSearchDataTypeToAsciiAction}" />
			<TextBox x:Name="SearchTextBox" Grid.Column="3" Margin="8,0,8,0" Watermark="hex bytes or ASCII text" Text="{Binding MemorySearchValue, Mode=TwoWay}" FontFamily="RobotoMonoFont" />
			<Button Grid.Column="4" Command="{Binding FirstOccurrenceAction}" IsEnabled="{Binding !IsBusy}" Content="Find first" />
			<Button Grid.Column="5" Margin="8,0,0,0" Command="{Binding NextOccurrenceAction}" IsEnabled="{Binding !IsBusy}" Content="Find next" />
			<Button Grid.Column="6" Margin="8,0,0,0" Command="{Binding PreviousOccurrenceAction}" IsEnabled="{Binding !IsBusy}" Content="Find previous" />
			<Button Grid.Column="7" Margin="8,0,0,0" Command="{Binding SearchCancelAction}" IsVisible="{Binding IsBusy}" Content="Cancel" />
			<Button Grid.Column="8" Margin="8,0,0,0" IsVisible="{Binding ShowOpenFoundOccurrenceAction}" IsEnabled="{Binding CanOpenFoundOccurrence}" Command="{Binding OpenFoundOccurrenceAction}" Content="Open in new view" />
			<TextBlock Grid.Column="9" Margin="16,0,8,0" VerticalAlignment="Center" Text="Found:" FontWeight="Bold" />
			<TextBlock Grid.Column="10" VerticalAlignment="Center" Text="{Binding FoundOccurrenceDisplay}" FontFamily="RobotoMonoFont" />
			<Button Grid.Column="11" HorizontalAlignment="Right" Command="{Binding StopMemorySearchAction}" Content="Close" HotKey="Escape" ToolTip.Tip="Esc" />
		</Grid>
	</Border>
</UserControl>

<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Spice86.ViewModels"
    xmlns:storage="using:Spice86.Shared.Emulator.Storage"
    xmlns:converters="using:Spice86.Views.Converters"
    mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="24"
    x:Class="Spice86.Views.UserControls.DriveStatusUserControl"
    x:CompileBindings="True" x:DataType="vm:DriveStatusViewModel">

    <UserControl.Resources>
        <converters:MediaPresenceBrushConverter x:Key="MediaPresenceBrushConverter" />
    </UserControl.Resources>

    <!-- Shows one small indicator per mounted DOS drive, polling every second -->
    <ItemsControl ItemsSource="{Binding DriveStatuses}" Margin="4,0">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="6" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="storage:DosVirtualDriveStatus">
                <Border BorderBrush="Gray" BorderThickness="1"
                        CornerRadius="3" Padding="4,1"
                        Background="{Binding HasMedia, Converter={StaticResource MediaPresenceBrushConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock FontSize="11" FontFamily="Monospace"
                                   Text="{Binding DriveLetter, StringFormat={}{0}:}" />
                        <TextBlock FontSize="10"
                                   Text="{Binding DriveType}" Opacity="0.7" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>

<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Spice86.ViewModels"
    xmlns:storage="using:Spice86.Shared.Emulator.Storage"
    mc:Ignorable="d" d:DesignWidth="120" d:DesignHeight="24"
    x:Class="Spice86.Views.UserControls.DriveStatusUserControl"
    x:CompileBindings="True" x:DataType="vm:DriveStatusViewModel">

    <StackPanel Orientation="Horizontal" Spacing="6">
        <ToolTip.Tip>
            <StackPanel Spacing="4" MaxWidth="420">
                <ItemsControl ItemsSource="{Binding DriveStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="storage:DosVirtualDriveStatus">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                <TextBlock FontFamily="Monospace" FontSize="11"
                                           Text="{Binding DriveLetter, StringFormat={}{0}:}" MinWidth="20" />
                                <TextBlock FontSize="10" Text="{Binding DriveType}" Opacity="0.7" MinWidth="48" />
                                <TextBlock FontSize="10" Text="{Binding VolumeLabel}" MinWidth="60" />
                                <TextBlock FontSize="10" FontFamily="Monospace"
                                           Text="{Binding CurrentImageFileName}" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ToolTip.Tip>
        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{Binding SummaryColor}" />
        <TextBlock Text="{Binding DriveCountText}" FontWeight="SemiBold" />
    </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Spice86.ViewModels"
             xmlns:converters="clr-namespace:Spice86.Views.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:MemoryBitmapViewModel"
             x:Class="Spice86.Views.MemoryBitmapView">
  <Grid RowDefinitions="Auto,Auto,*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
      <Label Content="Display Mode:" VerticalAlignment="Center" Margin="0,0,5,0"/>
      <ComboBox ItemsSource="{Binding AvailableDisplayModes}"
                SelectedItem="{Binding DisplayMode}"
                MinWidth="150" VerticalAlignment="Center">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Converter={x:Static converters:MemoryBitmapDisplayModeConverter.ToDisplayName}}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>
    <Button Grid.Row="1" Content="Save..." Command="{Binding SaveCommand}" Margin="5,0,0,5" HorizontalAlignment="Left"/>
	<Image Grid.Row="2"
		RenderOptions.BitmapInterpolationMode="None"
		Source="{Binding Bitmap}" />
  </Grid>
</UserControl>

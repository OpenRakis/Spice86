<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Spice86.ViewModels"
        x:Class="Spice86.Views.HttpApiWindow"
        x:CompileBindings="True"
        x:DataType="vm:HttpApiViewModel"
        Width="760"
        Height="520"
        MinWidth="700"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        CanResize="True"
        Title="Spice86 HTTP API"
        Icon="/Views/Assets/Spice86.ico"
        mc:Ignorable="d">
    <Design.DataContext>
        <vm:HttpApiViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="14" RowSpacing="12">
        <Border Grid.Row="0" CornerRadius="8" Padding="12" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="HTTP API" />
                <TextBlock Grid.Row="1" Text="{Binding BaseUrl, StringFormat='Base URL: {0}'}" />
                <TextBlock Grid.Row="2" Text="{Binding IsEnabled, StringFormat='Enabled: {0}'}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="8" Padding="12" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Content="Refresh" Command="{Binding RefreshStatusCommand}" MinWidth="92" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Status, StringFormat='State: {0}'}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding CpuPointer, StringFormat='CS:IP: {0}'}" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding Cycles, StringFormat='Cycles: {0:N0}'}" />
                <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding LastMessage}" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="8" Padding="12" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,120,Auto,120,Auto,Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Address" />
                <TextBox Grid.Column="1" Text="{Binding MemoryAddressInput}" Watermark="0x00000" />

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Value" />
                <TextBox Grid.Column="3" Text="{Binding MemoryValueInput}" Watermark="0x00" />

                <Button Grid.Column="4" Content="Read" Command="{Binding ReadByteCommand}" MinWidth="82" />
                <Button Grid.Column="5" Content="Write" Command="{Binding WriteByteCommand}" MinWidth="82" />
                <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="{Binding LastReadValue, StringFormat='Read value: {0}'}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" CornerRadius="8" Padding="12" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Quick Start" />
                <TextBlock Text="1) API endpoint is fixed to 127.0.0.1:10001" />
                <TextBlock Text="2) Click Refresh to validate API status" />
                <TextBlock Text="3) Use Read/Write to test memory byte endpoints" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Spice86.ViewModels"
        x:Class="Spice86.Views.HttpApiWindow"
        x:CompileBindings="True"
        x:DataType="vm:HttpApiViewModel"
        Width="760"
        Height="520"
        MinWidth="700"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        CanResize="True"
        Title="Spice86 HTTP API"
        Icon="/Views/Assets/Spice86.ico"
        mc:Ignorable="d">
    <Design.DataContext>
        <vm:HttpApiViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="12">
        <Border Grid.Row="0" CornerRadius="10" Padding="14" BorderThickness="1">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="HTTP API Console" />
                <TextBlock Grid.Row="1" Text="{Binding BaseUrl, StringFormat='Endpoint: {0}'}" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding IsEnabled, StringFormat='Available: {0}'}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0" CornerRadius="10" Padding="14" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <TextBlock FontWeight="SemiBold" FontSize="15" Text="Session" />
                    <Button Grid.Row="1" Content="Refresh Status" Command="{Binding RefreshStatusCommand}" MinWidth="120" HorizontalAlignment="Left" />
                    <TextBlock Grid.Row="2" Text="{Binding Status, StringFormat='State: {0}'}" />
                    <TextBlock Grid.Row="3" Text="{Binding CpuPointer, StringFormat='CS:IP: {0}'}" />
                    <TextBlock Grid.Row="4" Text="{Binding Cycles, StringFormat='Cycles: {0:N0}'}" />
                    <TextBlock Grid.Row="5" Text="{Binding LastMessage}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="10" Padding="14" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <TextBlock FontWeight="SemiBold" FontSize="15" Text="Memory Probe" />
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Address" />
                        <TextBox Grid.Column="1" Text="{Binding MemoryAddressInput}" Watermark="0x00000" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Value" />
                        <TextBox Grid.Column="1" Text="{Binding MemoryValueInput}" Watermark="0x00" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Content="Read" Command="{Binding ReadByteCommand}" MinWidth="86" />
                        <Button Grid.Column="1" Content="Write" Command="{Binding WriteByteCommand}" MinWidth="86" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding LastReadValue, StringFormat='Read value: {0}'}" />
                    </Grid>
                    <TextBlock Grid.Row="4" Text="Supported: /api/status, /api/memory/{address}/byte, /api/memory/{address}/range/{length}" TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" CornerRadius="10" Padding="12" BorderThickness="1">
            <TextBlock Text="Fixed endpoint: 127.0.0.1:10001" />
        </Border>
    </Grid>
</Window>
